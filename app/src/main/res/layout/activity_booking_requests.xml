<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- ===== Top Bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_previous"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Booking Requests"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"/>
    </LinearLayout>


    <!-- ===== Body ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Filter Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="3 new requests"
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:layout_height="wrap_content"/>

                <Button
                    android:layout_width="70dp"
                    android:layout_height="35dp"
                    android:textSize="10sp"
                    android:text="New"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#2563EB"/>

                <Button
                    android:layout_width="70dp"
                    android:layout_height="35dp"
                    android:text="All"
                    android:textAllCaps="false"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>


            <!-- ===== Booking Card ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_cadu"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <!-- Name + Price -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Ahmed Rahman"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Electrical Wiring"
                            android:textColor="#6B7280"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView
                        android:text="৳500"
                        android:textColor="#2563EB"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginVertical="12dp"/>

                <!-- Date & Time -->
                <TextView
                    android:text="📅 Dec 28, 2024   ⏰ 10:00 AM"
                    android:textColor="#374151"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Location -->
                <TextView
                    android:text="📍 Shaheb Bazar, Rajshahi"
                    android:textColor="#374151"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Note Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F3F4F6"
                    android:padding="12dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:text="Need to install new electrical outlets in living room"
                        android:textColor="#374151"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="45dp"
                        android:text="Accept"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#16A34A"/>

                    <Button
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="45dp"
                        android:text="Decline"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Contact Button -->
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:text="Contact Client"
                    android:textAllCaps="false"
                    android:textColor="#2563EB"
                    android:backgroundTint="#E0E7FF"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_cadu"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <!-- Name + Price -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Rabeya Khatun"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Electrical Wiring"
                            android:textColor="#6B7280"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView
                        android:text="৳500"
                        android:textColor="#2563EB"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginVertical="12dp"/>

                <!-- Date & Time -->
                <TextView
                    android:text="📅 Dec 28, 2024   ⏰ 10:00 AM"
                    android:textColor="#374151"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Location -->
                <TextView
                    android:text="📍 Rani Bazar, Rajshahi"
                    android:textColor="#374151"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Note Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F3F4F6"
                    android:padding="12dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:text="Need to install new electrical outlets in living room"
                        android:textColor="#374151"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="45dp"
                        android:text="Accept"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#16A34A"/>

                    <Button
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="45dp"
                        android:text="Decline"
                        android:textAllCaps="false"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Contact Button -->
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:text="Contact Client"
                    android:textAllCaps="false"
                    android:textColor="#2563EB"
                    android:backgroundTint="#E0E7FF"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>