<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup Provider Profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111827"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complete your profile to start receiving booking requests"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#6B7280"
            android:layout_marginBottom="20dp"/>

        <!-- Profile Photo Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_cardd"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile Photo"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"
                android:layout_marginBottom="16dp"/>

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_upload"
                android:background="@drawable/bg_circle"
                android:padding="30dp"/>

            <Button
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:text="Upload Photo"
                android:textAllCaps="false"
                android:textColor="#2563EB"
                android:background="@drawable/bg_light_button"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Service Category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cardd"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="Service Category"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#374151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Spinner
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Years of Experience -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cardd"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="Years of Experience"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#374151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g., 5"
                android:inputType="number"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Service Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cardd"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="Service Area"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#374151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g., Rajshahi City"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Service Description -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cardd"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="Service Description"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#374151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Describe your services and expertise..."
                android:gravity="top"
                android:layout_marginTop="8dp"
                android:inputType="textMultiLine"/>
        </LinearLayout>

        <!-- Availability -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cardd"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:text="Availability"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Days -->
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saturday"
                />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunday"
                />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monday"
                />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuesday"
                />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wednesday"
                />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thursday"
                />
            <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fryday"
                />

        </LinearLayout>

        <!-- Complete Setup Button -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Complete Setup"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#2563EB"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>

</ScrollView>